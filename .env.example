# 复制为项目根目录 .env 后填写（.env 勿提交 Git）

# 服务端口
SERVER_PORT=8080
FRONTEND_PORT=5173

# 前端 API 代理目标：local=本机 Spring Boot，remote=服务器 Docker 后端
BACKEND_TARGET=

# 本地后端（BACKEND_TARGET=local 时，Vite 代理 /api 到此）
BACKEND_LOCAL_HOST=127.0.0.1
BACKEND_LOCAL_PORT=8080

# 远程后端（BACKEND_TARGET=remote 时，Vite 代理 /api 到此）
BACKEND_REMOTE_HOST=hkwisesun.com
BACKEND_REMOTE_PORT=9019

# MySQL（lab_assess 表所在库，按实际环境填写，勿留空）
DB_HOST=sql.z150.vhostgo.com
DB_PORT=3306
DB_NAME=wisesun
DB_USERNAME=wisesun
DB_PASSWORD=anfang250923
DB_TIMEZONE=Asia/Shanghai
DB_JDBC_PARAMS=useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true

# JPA
JPA_SHOW_SQL=true

# CORS 允许来源（逗号分隔）
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# 可选：.env 不在默认位置时，设为 .env 的绝对路径
# DOTENV_PATH=
